generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  customer
  dealer

  @@map("user_role")
}

enum TyreType {
  Summer
  Rainy
  AllSeason

  @@map("tyre_type")
}

enum OrderPaymentMethod {
  bank_transfer
  cod

  @@map("order_payment_method")
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled

  @@map("order_status")
}

/// Extends auth.users (managed by Supabase Auth — not modeled here).
/// id matches auth.users.id 1:1; the FK constraint lives in the SQL
/// migration since Prisma doesn't manage the `auth` schema.
model Profile {
  id          String   @id @db.Uuid
  email       String   @unique
  fullName    String?  @map("full_name")
  companyName String?  @map("company_name")
  role        UserRole @default(customer)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Product {
  id     String  @id @default(uuid()) @db.Uuid
  sku    String  @unique
  ean    String?
  name   String
  brand  String
  imageUrl String? @map("image_url")

  // Fitment
  width       Int
  profile     Int
  rimSize     Int      @map("rim_size")
  speedRating String   @map("speed_rating")
  loadIndex   Int      @map("load_index")
  tyreType    TyreType @map("tyre_type")

  // EU label ratings
  wetGripRating        String? @map("wet_grip_rating") @db.Char(1)
  fuelEfficiencyRating String? @map("fuel_efficiency_rating") @db.Char(1)
  noiseLevelDb         Int?    @map("noise_level_db")

  // Commercial
  stock       Int     @default(0)
  priceRetail Decimal @map("price_retail") @db.Decimal(10, 2)
  priceDealer Decimal @map("price_dealer") @db.Decimal(10, 2)

  // Merchandising
  rating      Decimal? @db.Decimal(2, 1)
  reviewCount Int      @default(0) @map("review_count")
  tags        String[] @default([])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pricingTiers PricingTier[]
  inventory    Inventory[]

  @@index([width, profile, rimSize])
  @@index([tyreType])
  @@map("products")
}

model Warehouse {
  id     String  @id @default(uuid()) @db.Uuid
  name   String  @unique
  region String?

  inventory Inventory[]

  @@map("warehouses")
}

model Inventory {
  productId   String @map("product_id") @db.Uuid
  warehouseId String @map("warehouse_id") @db.Uuid
  quantity    Int    @default(0)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([productId, warehouseId])
  @@map("inventory")
}

model PricingTier {
  id           String  @id @default(uuid()) @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  minQty       Int     @map("min_qty")
  maxQty       Int?    @map("max_qty")
  pricePerUnit Decimal @map("price_per_unit") @db.Decimal(10, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("pricing_tiers")
}

model Order {
  id          String  @id @default(uuid()) @db.Uuid
  orderNumber String  @unique @map("order_number")
  userId      String? @map("user_id") @db.Uuid

  customerName  String  @map("customer_name")
  customerPhone String  @map("customer_phone")
  customerEmail String? @map("customer_email")
  addressLine   String  @map("address_line")
  city          String
  postalCode    String  @map("postal_code")
  notes         String?

  paymentMethod      OrderPaymentMethod @map("payment_method")
  status             OrderStatus        @default(pending)
  subtotal           Decimal            @db.Decimal(10, 2)
  installationTotal  Decimal            @default(0) @map("installation_total") @db.Decimal(10, 2)
  total              Decimal            @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  productName String  @map("product_name")
  sku         String
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  installation Boolean @default(false)
  subtotal    Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}
